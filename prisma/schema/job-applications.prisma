model JobApplication {
  id        String   @id @default(cuid())
  userId    String
  jobId     String
  jobTitle  String
  company   String
  applyUrl  String
  status    String   @default("Applied")
  appliedAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, jobId])
  @@index([userId])
  @@index([status, updatedAt])
}
