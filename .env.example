# Required on Vercel
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
BETTER_AUTH_SECRET="generate-a-long-random-secret"
NEXT_PUBLIC_APP_URL="https://your-vercel-domain.vercel.app"
BETTER_AUTH_URL="https://your-vercel-domain.vercel.app"

# Search providers
ADZUNA_APP_ID="your-adzuna-app-id"
ADZUNA_APP_KEY="your-adzuna-app-key"
# Optional but strongly recommended: enables Google Jobs and public web discovery
# across company career pages and public job result pages.
SERPAPI_API_KEY=""
# Optional structured jobs source with normalized dates and employer URLs.
THEIRSTACK_API_KEY=""

# AI chat / AI helpers
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"

# Resume upload on Vercel
BLOB_READ_WRITE_TOKEN=""

# Email on Vercel
RESEND_API_KEY=""
RESEND_FROM="InternAI <hello@your-domain.com>"

# Stripe checkout/payment verification
STRIPE_SECRET_KEY=""
# Stripe recurring monthly Price ID for Basic ($5/month)
STRIPE_BASIC_PRICE_ID=""
# Stripe recurring monthly Price ID for Premium ($10/month)
STRIPE_PREMIUM_PRICE_ID=""

# Optional: protect Vercel cron endpoints. If set, Vercel should send
# Authorization: Bearer <CRON_SECRET>.
CRON_SECRET=""

# Optional admin seed
OWNER_EMAIL=""
